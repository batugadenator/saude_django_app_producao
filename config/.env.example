# Django
DJANGO_SETTINGS_MODULE=saude_project.settings.prod
DEBUG=0
SECRET_KEY=troque-esta-chave-em-producao
ALLOWED_HOSTS=localhost,127.0.0.1,seu-dominio.com

# Banco principal
POSTGRES_DB=saude
POSTGRES_USER=saude
POSTGRES_PASSWORD=saude
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Banco externo (source)
SOURCE_DB_HOST=host-do-banco-fonte
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=nome_do_banco_fonte
SOURCE_DB_USER=usuario
SOURCE_DB_PASSWORD=senha

# Origem padrão de cadetes no banco externo
SOURCE_CADETES_ORIGEM=pessoa.cadastro_de_cadetes

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://seu-frontend.com

# SSL/Security (use em produção)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Proxy Configuration
USE_X_FORWARDED_HOST=True

# Logging
LOG_LEVEL=INFO

# Import automático (opcional): defina qualquer valor para habilitar
# AUTO_IMPORT_CADETES_SOURCE=1