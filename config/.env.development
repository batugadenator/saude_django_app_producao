# .env para desenvolvimento com SQLite
# Use este arquivo para desenvolvimento rápido sem PostgreSQL

DEBUG=True
SECRET_KEY=dev-secret-key-insecure-only-for-local-dev-change-in-prod
ALLOWED_HOSTS=localhost,127.0.0.1,*
DJANGO_SETTINGS_MODULE=saude_project.settings.dev

# ⚡ ATIVAR SQLITE PARA DESENVOLVIMENTO
USE_SQLITE_DEV=True

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# Logging
LOG_LEVEL=DEBUG
